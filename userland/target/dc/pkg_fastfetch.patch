diff --git a/src/detection/maple/maple.h b/src/detection/maple/maple.h
new file mode 100644
index 00000000..9c1dc0a4
--- /dev/null
+++ b/src/detection/maple/maple.h
@@ -0,0 +1,16 @@
+#pragma once
+
+#include "fastfetch.h"
+
+// A single device on the Dreamcast Maple bus
+// (controllers, VMUs, keyboards, mice, vibration packs, ...)
+typedef struct FFMapleDevice {
+    FFstrbuf type;          // Human readable type, derived from the kernel driver name
+    uint8_t port;           // Physical port: 0 => A, 1 => B, ...
+    uint8_t unit;           // 0 => base device, 1+ => expansion slot
+    uint32_t functions;     // Maple function bitmask (e.g. 0xE for a VMU)
+    uint64_t storageBytes;  // Storage capacity in bytes (VMUs / memory cards), 0 if none
+    bool hasLcd;            // Whether the device exposes an LCD screen (VMUs)
+} FFMapleDevice;
+
+const char* ffDetectMaple(FFlist* devices /* List of FFMapleDevice */);
diff --git a/src/detection/maple/maple_linux.c b/src/detection/maple/maple_linux.c
new file mode 100644
index 00000000..9c0ae311
--- /dev/null
+++ b/src/detection/maple/maple_linux.c
@@ -0,0 +1,162 @@
+#include "maple.h"
+#include "common/io.h"
+#include "common/strutil.h"
+
+#include <dirent.h>
+
+// Turns a kernel driver name like "Dreamcast_visual_memory" into "Visual Memory".
+static void humanizeDriver(FFstrbuf* type, const char* driver) {
+    if (ffStrStartsWith(driver, "Dreamcast_")) {
+        driver += strlen("Dreamcast_");
+    }
+
+    bool startOfWord = true;
+    for (const char* p = driver; *p; ++p) {
+        char c = *p;
+        if (c == '\n' || c == '\r') {
+            break; // End of the DRIVER= line; ignore the rest of the uevent file
+        }
+        if (c == '_') {
+            if (type->length && !startOfWord) {
+                ffStrbufAppendC(type, ' ');
+            }
+            startOfWord = true;
+            continue;
+        }
+        if (startOfWord && c >= 'a' && c <= 'z') {
+            c = (char) (c - 'a' + 'A');
+        }
+        ffStrbufAppendC(type, c);
+        startOfWord = false;
+    }
+    ffStrbufTrimRightSpace(type);
+}
+
+// Reads "DRIVER=..." out of a maple device's uevent file.
+static void readDriver(FFstrbuf* type, FFstrbuf* path) {
+    uint32_t baseLen = path->length;
+    ffStrbufAppendS(path, "uevent");
+
+    FF_STRBUF_AUTO_DESTROY uevent = ffStrbufCreate();
+    if (ffAppendFileBuffer(path->chars, &uevent)) {
+        const char* driver = strstr(uevent.chars, "DRIVER=");
+        if (driver) {
+            humanizeDriver(type, driver + strlen("DRIVER="));
+        }
+    }
+    ffStrbufSubstrBefore(path, baseLen);
+}
+
+// VMUs / memory cards expose their capacity through an MTD child device:
+//   <device>/mtd/mtd0/size
+static uint64_t readStorageBytes(FFstrbuf* path) {
+    uint32_t baseLen = path->length;
+    ffStrbufAppendS(path, "mtd/");
+
+    uint64_t bytes = 0;
+    FF_AUTO_CLOSE_DIR DIR* dirp = opendir(path->chars);
+    if (dirp) {
+        uint32_t mtdBaseLen = path->length;
+        struct dirent* entry;
+        while ((entry = readdir(dirp)) != NULL) {
+            if (entry->d_name[0] == '.') continue;
+
+            ffStrbufAppendS(path, entry->d_name);
+            ffStrbufAppendS(path, "/size");
+            char buf[32];
+            ssize_t nRead = ffReadFileData(path->chars, ARRAY_SIZE(buf) - 1, buf);
+            ffStrbufSubstrBefore(path, mtdBaseLen);
+            if (nRead > 0) {
+                buf[nRead] = '\0';
+                bytes = strtoull(buf, NULL, 10);
+                break;
+            }
+        }
+    }
+
+    ffStrbufSubstrBefore(path, baseLen);
+    return bytes;
+}
+
+// Fallback used when the kernel has no driver bound (uevent lacks DRIVER=):
+// derive a readable type from the Maple function bitmask instead.
+static void decodeFunctions(FFstrbuf* type, uint32_t functions) {
+    // Storage + LCD (+ clock) is the classic Visual Memory Unit
+    if ((functions & 0x002) && (functions & 0x004)) {
+        ffStrbufAppendS(type, "Visual Memory");
+        functions &= ~0x00EU; // consume storage | LCD | clock
+    }
+
+    static const struct { uint32_t bit; const char* name; } table[] = {
+        { 0x001, "Controller" },
+        { 0x040, "Keyboard" },
+        { 0x200, "Mouse" },
+        { 0x080, "Light Gun" },
+        { 0x020, "AR Gun" },
+        { 0x010, "Microphone" },
+        { 0x100, "Puru Puru" },
+        { 0x002, "Storage" },
+        { 0x004, "LCD" },
+        { 0x008, "Clock" },
+    };
+    for (uint32_t i = 0; i < ARRAY_SIZE(table); ++i) {
+        if (functions & table[i].bit) {
+            if (type->length) ffStrbufAppendS(type, ", ");
+            ffStrbufAppendS(type, table[i].name);
+        }
+    }
+}
+
+const char* ffDetectMaple(FFlist* devices /* List of FFMapleDevice */) {
+    FF_AUTO_CLOSE_DIR DIR* dirp = opendir("/sys/bus/maple/devices/");
+    if (dirp == NULL) {
+        return "opendir(\"/sys/bus/maple/devices/\") == NULL (is this a Dreamcast running Linux with maple bus support?)";
+    }
+
+    FF_STRBUF_AUTO_DESTROY path = ffStrbufCreateS("/sys/bus/maple/devices/");
+    uint32_t baseLen = path.length;
+
+    struct dirent* entry;
+    while ((entry = readdir(dirp)) != NULL) {
+        // Device dirs are named "<port>:<unit>.<functionHex>", e.g. "3:01.E"
+        if (!ffCharIsDigit(entry->d_name[0])) {
+            continue;
+        }
+
+        const char* name = entry->d_name;
+        char* end = NULL;
+        unsigned long port = strtoul(name, &end, 10);
+        if (*end != ':') continue;
+        unsigned long unit = strtoul(end + 1, &end, 10);
+        if (*end != '.') continue;
+        unsigned long functions = strtoul(end + 1, &end, 16);
+        if (*end != '\0') continue;
+
+        ffStrbufAppendS(&path, entry->d_name);
+        ffStrbufAppendC(&path, '/');
+
+        FFMapleDevice* device = FF_LIST_ADD(FFMapleDevice, *devices);
+        ffStrbufInit(&device->type);
+        device->port = (uint8_t) port;
+        device->unit = (uint8_t) unit;
+        device->functions = (uint32_t) functions;
+        device->storageBytes = 0;
+        device->hasLcd = false;
+
+        readDriver(&device->type, &path);
+        if (device->type.length == 0) {
+            // No kernel driver bound; name the device from its function bits
+            decodeFunctions(&device->type, device->functions);
+        }
+
+        // VMUs expose storage (MTD) and an LCD screen as child devices
+        device->storageBytes = readStorageBytes(&path);
+
+        ffStrbufAppendS(&path, "vmu_lcd");
+        device->hasLcd = ffPathExists(path.chars, FF_PATHTYPE_DIRECTORY);
+
+        ffStrbufSubstrBefore(&path, baseLen);
+    }
+
+    return NULL;
+}

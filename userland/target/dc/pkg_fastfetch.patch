diff --git a/src/modules/maple/maple.c b/src/modules/maple/maple.c
new file mode 100644
index 00000000..cbda8306
--- /dev/null
+++ b/src/modules/maple/maple.c
@@ -0,0 +1,157 @@
+#include "common/printing.h"
+#include "common/jsonconfig.h"
+#include "common/size.h"
+#include "detection/maple/maple.h"
+#include "modules/maple/maple.h"
+
+// Builds e.g. "Port D, Slot 1" from a device's physical location.
+static void appendLocation(FFstrbuf* buffer, const FFMapleDevice* device) {
+    ffStrbufAppendF(buffer, "Port %c", 'A' + device->port);
+    if (device->unit > 0) {
+        ffStrbufAppendF(buffer, ", Slot %u", (unsigned) device->unit);
+    }
+}
+
+static void printDevice(FFMapleOptions* options, const FFMapleDevice* device, uint8_t index) {
+    if (options->moduleArgs.outputFormat.length == 0) {
+        ffPrintLogoAndKey(FF_MAPLE_MODULE_NAME, index, &options->moduleArgs, FF_PRINT_TYPE_DEFAULT);
+
+        FF_STRBUF_AUTO_DESTROY buffer = ffStrbufCreate();
+        if (device->type.length)
+            ffStrbufAppend(&buffer, &device->type);
+        else
+            ffStrbufAppendS(&buffer, "Unknown device");
+
+        ffStrbufAppendS(&buffer, " (");
+        appendLocation(&buffer, device);
+
+        if (device->storageBytes > 0) {
+            ffStrbufAppendS(&buffer, ", ");
+            ffSizeAppendNum(device->storageBytes, &buffer);
+        }
+        if (device->hasLcd)
+            ffStrbufAppendS(&buffer, ", LCD");
+
+        ffStrbufAppendC(&buffer, ')');
+        ffStrbufPutTo(&buffer, stdout);
+    } else {
+        FF_STRBUF_AUTO_DESTROY location = ffStrbufCreate();
+        appendLocation(&location, device);
+
+        FF_STRBUF_AUTO_DESTROY size = ffStrbufCreate();
+        if (device->storageBytes > 0)
+            ffSizeAppendNum(device->storageBytes, &size);
+
+        FF_STRBUF_AUTO_DESTROY port = ffStrbufCreate();
+        ffStrbufAppendC(&port, (char) ('A' + device->port));
+
+        FF_PRINT_FORMAT_CHECKED(FF_MAPLE_MODULE_NAME, index, &options->moduleArgs, FF_PRINT_TYPE_DEFAULT, ((FFformatarg[]) {
+            FF_ARG(device->type, "type"),
+            FF_ARG(location, "location"),
+            FF_ARG(port, "port"),
+            FF_ARG(device->unit, "slot"),
+            FF_ARG(device->functions, "functions"),
+            FF_ARG(size, "storage"),
+            FF_ARG(device->hasLcd, "has-lcd"),
+        }));
+    }
+}
+
+bool ffPrintMaple(FFMapleOptions* options) {
+    FF_LIST_AUTO_DESTROY result = ffListCreate();
+
+    const char* error = ffDetectMaple(&result);
+
+    if (error) {
+        ffPrintError(FF_MAPLE_MODULE_NAME, 0, &options->moduleArgs, FF_PRINT_TYPE_DEFAULT, "%s", error);
+        return false;
+    }
+
+    if (!result.length) {
+        ffPrintError(FF_MAPLE_MODULE_NAME, 0, &options->moduleArgs, FF_PRINT_TYPE_DEFAULT, "No devices detected");
+        return false;
+    }
+
+    uint8_t index = 0;
+    FF_LIST_FOR_EACH (FFMapleDevice, device, result) {
+        printDevice(options, device, result.length > 1 ? ++index : 0);
+    }
+
+    FF_LIST_FOR_EACH (FFMapleDevice, device, result) {
+        ffStrbufDestroy(&device->type);
+    }
+
+    return true;
+}
+
+void ffParseMapleJsonObject(FFMapleOptions* options, yyjson_val* module) {
+    yyjson_val *key, *val;
+    size_t idx, max;
+    yyjson_obj_foreach (module, idx, max, key, val) {
+        if (ffJsonConfigParseModuleArgs(key, val, &options->moduleArgs)) {
+            continue;
+        }
+
+        ffPrintError(FF_MAPLE_MODULE_NAME, 0, &options->moduleArgs, FF_PRINT_TYPE_DEFAULT, "Unknown JSON key %s", unsafe_yyjson_get_str(key));
+    }
+}
+
+void ffGenerateMapleJsonConfig(FFMapleOptions* options, yyjson_mut_doc* doc, yyjson_mut_val* module) {
+    ffJsonConfigGenerateModuleArgsConfig(doc, module, &options->moduleArgs);
+}
+
+bool ffGenerateMapleJsonResult(FF_A_UNUSED FFMapleOptions* options, yyjson_mut_doc* doc, yyjson_mut_val* module) {
+    FF_LIST_AUTO_DESTROY result = ffListCreate();
+
+    const char* error = ffDetectMaple(&result);
+
+    if (error) {
+        yyjson_mut_obj_add_str(doc, module, "error", error);
+        return false;
+    }
+
+    yyjson_mut_val* arr = yyjson_mut_obj_add_arr(doc, module, "result");
+    FF_LIST_FOR_EACH (FFMapleDevice, device, result) {
+        yyjson_mut_val* obj = yyjson_mut_arr_add_obj(doc, arr);
+        yyjson_mut_obj_add_strbuf(doc, obj, "type", &device->type);
+        yyjson_mut_obj_add_uint(doc, obj, "port", device->port);
+        yyjson_mut_obj_add_uint(doc, obj, "slot", device->unit);
+        yyjson_mut_obj_add_uint(doc, obj, "functions", device->functions);
+        yyjson_mut_obj_add_uint(doc, obj, "storageBytes", device->storageBytes);
+        yyjson_mut_obj_add_bool(doc, obj, "hasLcd", device->hasLcd);
+    }
+
+    FF_LIST_FOR_EACH (FFMapleDevice, device, result) {
+        ffStrbufDestroy(&device->type);
+    }
+
+    return true;
+}
+
+void ffInitMapleOptions(FFMapleOptions* options) {
+    ffOptionInitModuleArg(&options->moduleArgs, "󰊴");
+}
+
+void ffDestroyMapleOptions(FFMapleOptions* options) {
+    ffOptionDestroyModuleArg(&options->moduleArgs);
+}
+
+FFModuleBaseInfo ffMapleModuleInfo = {
+    .name = FF_MAPLE_MODULE_NAME,
+    .description = "List devices connected to the Dreamcast Maple bus",
+    .initOptions = (void*) ffInitMapleOptions,
+    .destroyOptions = (void*) ffDestroyMapleOptions,
+    .parseJsonObject = (void*) ffParseMapleJsonObject,
+    .printModule = (void*) ffPrintMaple,
+    .generateJsonResult = (void*) ffGenerateMapleJsonResult,
+    .generateJsonConfig = (void*) ffGenerateMapleJsonConfig,
+    .formatArgs = FF_FORMAT_ARG_LIST(((FFModuleFormatArg[]) {
+        { "Device type", "type" },
+        { "Physical location (e.g. \"Port D, Slot 1\")", "location" },
+        { "Port letter (A-D)", "port" },
+        { "Expansion slot (0 = base device)", "slot" },
+        { "Maple function bitmask", "functions" },
+        { "Storage capacity (VMUs)", "storage" },
+        { "Whether the device has an LCD screen", "has-lcd" },
+    }))
+};

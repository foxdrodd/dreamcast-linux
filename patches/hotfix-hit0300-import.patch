+# SPDX-License-Identifier: GPL-2.0-only
+#
+# Fujitsu Network device configuration
+#
+
+config NET_VENDOR_FUJITSU
+	bool "Fujitsu devices"
+	default y
+	depends on SH_DREAMCAST
+	help
+	  If you have a network (Ethernet) card belonging to this class, say Y.
+
+	  Note that the answer to this question doesn't directly affect the
+	  kernel: saying N will just cause the configurator to skip all the
+	  questions about Fujitsu cards. If you say Y, you will be asked for
+	  your specific card in the following questions.
+
+if NET_VENDOR_FUJITSU
+
+config LAN_ADAPTER
+	tristate "SEGA Dreamcast HIT-0300 LAN adapter support"
+	depends on SH_DREAMCAST
+	select CRC32
+	help
+	  Driver for the SEGA HIT-0300 LAN adapter, a 10baseT Ethernet
+	  adapter for the Dreamcast expansion (G2) bus built around the
+	  Fujitsu MB86967 controller.
+
+	  To compile this driver as a module, choose M here: the module
+	  will be called lan_adapter.
+
+endif # NET_VENDOR_FUJITSU

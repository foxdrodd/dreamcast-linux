From 7b9c7fc14559ac322b1b94e07280be6bc5270354 Mon Sep 17 00:00:00 2001
From: Florian Fuchs <fuchsfl@gmail.com>
Date: Mon, 07 Jul 2026 12:00:00 +0200
Subject: [PATCH] sh: dreamcast: make BBA (rtl8139) work in both MMIO and PIO

The BBA is an RTL8139 behind the GAPS bridge, reachable via BAR1 (MMIO,
8139too default) or BAR0 (PIO). Both are fixed-decoded to the same regs at
phys 0x01001700, and __set_io_port_base(P2SEG) makes an I/O port a P2 memory
access. The stock code exports only one IORESOURCE_IO window, so the PCI core
can't find a matching-type parent for the BARs and probe fails with -22.

Fix:

  1. Add overlapping IO + MEM host-bridge windows so both BARs get a
     matching-type parent (they live in separate resource trees).
  2. Pin BAR0 to 0x01001700 (like BAR1); the regs aren't 0x400-aligned, so
     an unpinned BAR0 would be relocated and PIO would miss them.
  3. Set io_map_base = P2SEG, required for ioport_map() under
     CONFIG_PCI_DOMAINS and to route PIO to the regs.

Signed-off-by: Florian Fuchs <fuchsfl@gmail.com>
---
 arch/sh/drivers/pci/pci-dreamcast.c    | 14 ++++++++++++++
 arch/sh/drivers/pci/fixups-dreamcast.c |  9 +++++++++
 2 files changed, 23 insertions(+)

diff --git a/arch/sh/drivers/pci/pci-dreamcast.c b/arch/sh/drivers/pci/pci-dreamcast.c
--- a/arch/sh/drivers/pci/pci-dreamcast.c
+++ b/arch/sh/drivers/pci/pci-dreamcast.c
@@ -22,6 +22,11 @@
 #include <asm/irq.h>
 #include <mach/pci.h>

+/*
+ * RTL8139 registers are reachable via both BAR0 (I/O) and BAR1 (MMIO).
+ * Overlapping IO + MEM windows so either BAR gets a matching-type parent.
+ * IO window must stay at index 0 (pcibios_align_resource() uses resources[0]).
+ */
 static struct resource gapspci_resources[] = {
 	{
 		.name	= "GAPSPCI IO",
@@ -29,6 +34,11 @@
 		.end	= GAPSPCI_BBA_CONFIG + GAPSPCI_BBA_CONFIG_SIZE - 1,
 		.flags	= IORESOURCE_IO,
 	},  {
+		.name	= "GAPSPCI regs",
+		.start	= GAPSPCI_BBA_CONFIG,
+		.end	= GAPSPCI_BBA_CONFIG + GAPSPCI_BBA_CONFIG_SIZE - 1,
+		.flags	= IORESOURCE_MEM,
+	},  {
 		.name	= "GAPSPCI mem",
 		.start	= GAPSPCI_DMA_BASE,
 		.end	= GAPSPCI_DMA_BASE + GAPSPCI_DMA_SIZE - 1,
@@ -42,6 +52,9 @@
 	.nr_resources	= ARRAY_SIZE(gapspci_resources),
 	.io_offset	= 0x00000000,
 	.mem_offset	= 0x00000000,
+	/* PIO ports go through P2 (matches __set_io_port_base(P2SEG)); also
+	 * required or ioport_map() panics under CONFIG_PCI_DOMAINS. */
+	.io_map_base	= P2SEG,
 };

 /*
 * gapspci init
 */
diff --git a/arch/sh/drivers/pci/fixups-dreamcast.c b/arch/sh/drivers/pci/fixups-dreamcast.c
--- a/arch/sh/drivers/pci/fixups-dreamcast.c
+++ b/arch/sh/drivers/pci/fixups-dreamcast.c
@@ -48,6 +48,15 @@
 		dev->resource[1].flags |= IORESOURCE_PCI_FIXED;

 		/*
+		 * Pin BAR0 (PIO) to the same fixed regs as BAR1.  Regs aren't
+		 * 0x400-aligned, so an unpinned BAR0 would be relocated and PIO
+		 * would hit the wrong address.
+		 */
+		dev->resource[0].start	= p->resources[0].start  + 0x100;
+		dev->resource[0].end	= dev->resource[0].start + 0x200 - 1;
+		dev->resource[0].flags	= IORESOURCE_IO | IORESOURCE_PCI_FIXED;
+
+		/*
 		 * Redirect dma memory allocations to special memory window.
 		 *
 		 * If this GAPSPCI region were mapped by a BAR, the CPU
--
